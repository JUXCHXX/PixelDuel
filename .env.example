#!/usr/bin/env node
# Firebase Configuration
# Copia este archivo a .env y rellena con tus valores de Firebase

# ============================================
# VARIABLES DE ENTORNO - FIREBASE
# ============================================

# API Key de Firebase (encontrada en Firebase Console > Configuración del proyecto)
VITE_FIREBASE_API_KEY=AIzaSyD_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Auth Domain (encontrada en Firebase Console)
VITE_FIREBASE_AUTH_DOMAIN=pixelduel-xxxxx.firebaseapp.com

# Project ID (encontrada en Firebase Console)
VITE_FIREBASE_PROJECT_ID=pixelduel-12345

# Storage Bucket (encontrada en Firebase Console)
VITE_FIREBASE_STORAGE_BUCKET=pixelduel-12345.appspot.com

# Messaging Sender ID (encontrada en Firebase Console)
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012

# App ID (encontrada en Firebase Console)
VITE_FIREBASE_APP_ID=1:123456789012:web:abcdef1234567890

# Database URL - IMPORTANTE para Realtime Database
VITE_FIREBASE_DATABASE_URL=https://pixelduel-xxxxx-default-rtdb.firebaseio.com

# ============================================
# DESARROLLO/PRODUCCIÓN (Opcional)
# ============================================

# Modo de desarrollo (true) o producción (false)
VITE_DEV_MODE=true

# Port para desarrollo local
VITE_PORT=5173
